{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "public",
  "framework": null,
  "rewrites": [
    { "source": "/api", "destination": "/api/index.mjs" },
    { "source": "/api/(.*)", "destination": "/api/index.mjs" }
  ]
}
